<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- PRODUCTION: Only allow HTTPS -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <trust-anchors includeSubdomains="false">
                <!-- Trust only system CA certificates in production -->
                <certificates src="system" />
            </trust-anchors>
        </trust-anchors>
    </base-config>
    <!-- OPTIONAL: For debug builds only, allow cleartext/debug CAs -->
    <!--
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
        <base-config cleartextTrafficPermitted="true" />
    </debug-overrides>
    -->
</network-security-config>
